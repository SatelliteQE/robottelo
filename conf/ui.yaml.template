UI:
  SCREENSHOTS_PATH: '@format {env[ROBOTTELO_DIR]}/screenshots/'

  # Browser to use for Playwright. Valid values: chromium, firefox
  WEBDRIVER: chromium
  # Run browser in headless mode (no visible window)
  HEADLESS: true
  # Slow down Playwright actions by this many milliseconds (useful for debugging)
  SLOW_MO: 0
  # Additional browser launch arguments (semicolon-separated)
  BROWSEROPTIONS:
